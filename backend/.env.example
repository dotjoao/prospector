# Project URL (Settings → API)
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave secreta do servidor (Settings → API → Secret key)
SUPABASE_SECRET_KEY=sua_secret_key_aqui

# Senha do PostgreSQL (Settings → Database → Database password)
# Necessária para criar tabelas automaticamente
SUPABASE_DB_PASSWORD=sua_senha_do_banco

# Ou connection string completa (opcional, substitui SUPABASE_DB_PASSWORD)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

API_PORT=3333
