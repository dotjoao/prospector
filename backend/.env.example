# Project URL (Settings → API)
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave secreta do servidor (Settings → API → Secret key)
SUPABASE_SECRET_KEY=sua_secret_key_aqui

# Senha do PostgreSQL (Settings → Database → Database password)
SUPABASE_DB_PASSWORD=sua_senha_do_banco

# Porta (Render/Railway definem PORT automaticamente)
# API_PORT=3333

# URL do frontend na Vercel (CORS) — pode ser mais de uma, separadas por vírgula
# FRONTEND_URL=https://leadhunter.vercel.app
